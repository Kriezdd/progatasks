//4) Создайте функцию, которая организует простейшей сжатие входящей символьной строки произвольного масштаба.
//Сжатие происходит по следующему принципу: если в строке есть последовательность повторяющихся символов, то она заменяется
//на пару код символа и количество его повтора в строчке. Обеспечьте возможность ввода строки с клавиатуры.

#include <iostream>
#include <string>
#include <vector>
using namespace std;

string compress(string a) //функция сжатия строки
{
	string newStroka("");
	int count = 1, codeSymb, cntCodeSymb = 0, flag = 0; //флаг нам понадобится для пометки, что мы нашли последовательность одинаковых символов

	for (int i = 0; i < a.length(); i++) //цикл записи сжатой строки с просмотром введённой
	{

		if (a[i] == a[i + 1]) //если нашли рядом стоящие одинаковые символы
		{
			flag = 2; //флаг теперь =2 до тех пор, пока последовательность одинаковых символов  не прервалась
			count++; //тут мы подсчитываем сколько одинаковых символов стоит подряд
			codeSymb = (int)(a[i]); //берём код повторяющегося символа
		}
		else 
			if (flag == 2) //если мы просматривали цепочку повторяющихся символов и они закончились, то флаг =1
				flag = 1;

		if (flag == 1) //флаг =1 говорит программе о том, что цепочку повторяющихся символов посмотрели и у нас есть код символа и количество его повторений
		{
			newStroka.insert(newStroka.length(), to_string(codeSymb)); //заменяем цепочку повторящихся символов на его код
			newStroka.insert(newStroka.length(), to_string(count)); // и количество повторений
			flag = 0;
			continue;
		}

		if (flag !=2)
			newStroka.push_back(a[i]);
		
	}

	return newStroka;
}

int main()
{
	string stroka;

	cout << "Enter string: \n";
	getline(cin, stroka);  //ввели строку

	cout << compress(stroka); //вывели из функции сжатия изменённую строку

